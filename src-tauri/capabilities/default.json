{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Gadaj main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "core:app:default",
    "core:event:default",
    "core:tray:default",
    "core:menu:default",
    "core:path:default",
    "log:default",
    "dialog:default",
    "os:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "store:default",
    "global-shortcut:default",
    "process:default",
    "clipboard-manager:default",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    "updater:default",
    "autostart:default"
  ]
}
