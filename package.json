{
  "name": "gadaj",
  "version": "0.1.0",
  "description": "Polska, open-source apka do dyktowania offline z Parakeet",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "build:full": "bun run build && bun run tauri:build && bash scripts/copy_ggml_to_bundle.sh",
